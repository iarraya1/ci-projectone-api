{
	"info": {
		"_postman_id": "d18cbe57-5039-4fcf-9a14-1c19088d47d8",
		"name": "DemoAPITests",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "22860530"
	},
	"item": [
		{
			"name": "Health Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
							"pm.test(\"JSON present\", () => pm.response.to.be.json);",
							"",
							"//Echo API echoes query args under 'args'",
							"const body = pm.response.json();",
							"pm.test(\"Echoed 'ping' is ok\", () => pm.expect(body.args.ping).to.eql(\"ok\"));",
							"",
							"//A couple of realistic checks beginners qill recognize:",
							"pm.test(\"Response time < 800ms\", () => pm.expect(pm.response.responseTime).to.be.below(800));",
							"pm.test(\"Content-Type is JSON\", () => pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\"));"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/get?ping=ok",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"get"
					],
					"query": [
						{
							"key": "ping",
							"value": "ok"
						}
					]
				}
			},
			"response": []
		},
		{
			"name": "Create User",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
							"",
							"const res = pm.response.json();",
							"",
							"// postman-echo returns the JSON you sent under 'json'",
							"pm.test(\"Has 'name' and 'email'\", () => {",
							"    pm.expect(res.json).to.have.property('name');",
							"    pm.expect(res.json).to.have.property('email');",
							"});",
							"",
							"//Minimal JSON schema validation",
							"const schema = {",
							"    type: \"object\",",
							"    properties: {",
							"        json: {",
							"            type: \"object\",",
							"            properties: {",
							"                name: { type: \"string\"},",
							"                email: { type: \"string\", format: \"email\" }",
							"            },",
							"            required: [\"name\", \"email\"],",
							"            additionalProperties: true",
							"        }",
							"    },",
							"    required: [\"json\"],",
							"    additionalProperties: true",
							"};",
							"",
							"pm.test(\"Schema is valid\", () => pm.response.to.have.jsonSchema(schema));",
							"",
							"// Bonus: capture a value for later requests",
							"pm.environment.set(\"userEmail\", res.json.email);"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\"name\": \"Alice\", \"email\": \"alice@example.com\"}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/post",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"post"
					]
				}
			},
			"response": []
		},
		{
			"name": "Not Found",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Should return 404\", () => pm.response.to.have.status(404));",
							"pm.test(\"Body can be empty or minimal\", () => pm.expect(pm.response.text()).to.be.a(\"string\"));"
						],
						"type": "text/javascript",
						"packages": {},
						"requests": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/status/404",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"status",
						"404"
					]
				}
			},
			"response": []
		}
	]
}